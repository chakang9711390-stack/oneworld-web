generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum IndustryType {
  opc
  workflow
  both
}

enum CommonStatus {
  active
  disabled
  archived
}

enum AuthProvider {
  email
  google
  apple
}

enum WorkspaceProjectStatus {
  active
  paused
  draft
  archived
}

enum SceneAutomationLevel {
  A1
  A2
  A3
}

enum SceneRiskLevel {
  R1
  R2
  R3
}

enum SceneFrequencyLevel {
  S
  A
  B
}

enum ScenePriorityLevel {
  P0
  P1
  P2
}

enum SceneSourceType {
  standard
  custom
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String?
  nickname          String?
  avatarUrl         String?
  authProvider      AuthProvider       @default(email)
  isAdmin           Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workspaceProjects WorkspaceProject[]
}

model Industry {
  id                    String               @id @default(cuid())
  name                  String
  slug                  String               @unique
  type                  IndustryType
  description           String?
  sortOrder             Int                  @default(0)
  status                CommonStatus         @default(active)
  businessGoals         String?
  commonOrgStructure    String?
  commonMetrics         String?
  commonTools           String?
  glossary              String?
  riskNotes             String?
  complianceNotes       String?
  maturityLevel         String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  opcProjectTemplates   OpcProjectTemplate[]
  workflowRoles         WorkflowRole[]
  workflowTemplates     WorkflowTemplate[]
  sceneDefinitions      SceneDefinition[]
}

model OpcProjectTemplate {
  id            String       @id @default(cuid())
  industryId    String
  title         String
  slug          String       @unique
  description   String?
  isCreateEntry Boolean      @default(false)
  sortOrder     Int          @default(0)
  status        CommonStatus @default(active)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  industry      Industry     @relation(fields: [industryId], references: [id], onDelete: Cascade)
}

model WorkflowRole {
  id                  String             @id @default(cuid())
  industryId          String
  name                String
  slug                String             @unique
  description         String?
  responsibility      String?
  sortOrder           Int                @default(0)
  status              CommonStatus       @default(active)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  industry            Industry           @relation(fields: [industryId], references: [id], onDelete: Cascade)
  workflowScenes      WorkflowScene[]
  workflowTemplates   WorkflowTemplate[]
  sceneDefinitions    SceneDefinition[]
}

model WorkflowScene {
  id                String           @id @default(cuid())
  roleId            String
  title             String
  slug              String           @unique
  description       String?
  isGenerateEntry   Boolean          @default(false)
  sortOrder         Int              @default(0)
  status            CommonStatus     @default(active)
  sourceType        String?          @default("seed")
  sceneDefinitionId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  role              WorkflowRole     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  sceneDefinition   SceneDefinition? @relation(fields: [sceneDefinitionId], references: [id], onDelete: SetNull)

  @@index([sceneDefinitionId])
}

model WorkflowTemplate {
  id                String            @id @default(cuid())
  industryId        String
  roleId            String
  code              String            @unique
  name              String
  slug              String            @unique
  description       String?
  businessGoal      String?
  cadence           String?
  sortOrder         Int               @default(0)
  status            CommonStatus      @default(active)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  industry          Industry          @relation(fields: [industryId], references: [id], onDelete: Cascade)
  role              WorkflowRole      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  sceneDefinitions  SceneDefinition[]
}

model SceneDefinition {
  id                    String                @id @default(cuid())
  sceneId               String                @unique
  name                  String
  slug                  String                @unique
  shortDescription      String?
  detailedDescription   String?
  businessGoal          String?
  painPoint             String?
  inputMaterials        String?
  outputResult          String?
  triggerType           String?
  cadence               String?
  automationLevel       SceneAutomationLevel?
  riskLevel             SceneRiskLevel?
  frequencyLevel        SceneFrequencyLevel?
  reusableLevel         String?
  commercialValue       String?
  launchPriority        ScenePriorityLevel?
  status                CommonStatus          @default(active)
  displayTitle          String?
  displaySubtitle       String?
  marketingSummary      String?
  directPurchase        Boolean               @default(false)
  customizationRequired Boolean               @default(false)
  industryId            String
  roleId                String
  workflowTemplateId    String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  industry              Industry              @relation(fields: [industryId], references: [id], onDelete: Cascade)
  role                  WorkflowRole          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  workflowTemplate      WorkflowTemplate      @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  executionConfig       SceneExecutionConfig?
  authConfig            SceneAuthConfig?
  riskRule              SceneRiskRule?
  versions              SceneVersion[]
  workflowScenes        WorkflowScene[]
}

model SceneExecutionConfig {
  id                      String          @id @default(cuid())
  sceneDefinitionId       String          @unique
  toolchainList           String?
  dependencyServices      String?
  environmentRequirements String?
  modelRequirements       String?
  preloadedKnowledge      String?
  executionStepsSummary   String?
  promptStrategyRef       String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  sceneDefinition         SceneDefinition @relation(fields: [sceneDefinitionId], references: [id], onDelete: Cascade)
}

model SceneAuthConfig {
  id                           String          @id @default(cuid())
  sceneDefinitionId            String          @unique
  authRequiredList             String?
  accountTypesRequired         String?
  loginStateRequired           String?
  fileAccessRequired           String?
  externalPlatformAccessRequired String?
  minimalPermissionScope       String?
  sensitivePermissions         String?
  authorizationNotes           String?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  sceneDefinition              SceneDefinition @relation(fields: [sceneDefinitionId], references: [id], onDelete: Cascade)
}

model SceneRiskRule {
  id                       String          @id @default(cuid())
  sceneDefinitionId        String          @unique
  humanConfirmationPoints  String?
  forbiddenActions         String?
  exceptionRules           String?
  rollbackSupported        Boolean         @default(false)
  rollbackNotes            String?
  alertingRequired         Boolean         @default(false)
  alertingChannels         String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  sceneDefinition          SceneDefinition @relation(fields: [sceneDefinitionId], references: [id], onDelete: Cascade)
}

model SceneVersion {
  id                      String          @id @default(cuid())
  sceneDefinitionId       String
  version                 String
  sourceType              SceneSourceType?
  maturityLevel           String?
  validatedCustomersCount Int             @default(0)
  owner                   String?
  releaseNotes            String?
  createdAt               DateTime        @default(now())
  sceneDefinition         SceneDefinition @relation(fields: [sceneDefinitionId], references: [id], onDelete: Cascade)

  @@unique([sceneDefinitionId, version])
}

model WorkspaceProject {
  id          String                 @id @default(cuid())
  userId      String
  title       String
  projectType String?
  sourceType  String?
  summary     String?
  status      WorkspaceProjectStatus @default(draft)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
